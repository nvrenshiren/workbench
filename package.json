{
  "name": "@dawipong/opcflow",
  "version": "0.11.0",
  "description": "Spec-anchored, drift-enforced execution layer for AI coding agents — artifact DAG, trust gates, multi-role pipeline; generates agents/MCP/hooks for Claude Code, Codex, OpenCode & Cursor.",
  "license": "MIT",
  "author": "Dawi",
  "homepage": "https://github.com/nvrenshiren/opcflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvrenshiren/opcflow.git"
  },
  "bugs": "https://github.com/nvrenshiren/opcflow/issues",
  "keywords": [
    "ai-agents",
    "coding-agent",
    "claude-code",
    "codex",
    "opencode",
    "cursor",
    "mcp",
    "spec-driven-development",
    "workflow-engine",
    "developer-tools"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.6.0",
  "bin": {
    "opcflow": "dist/cli.mjs"
  },
  "files": [
    "dist",
    "web/dist",
    "templates",
    "preset"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check:isolation": "tsx scripts/check-isolation.ts",
    "web:build": "vite build",
    "build": "pnpm run web:build && node scripts/build.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@fastify/cors": "^11",
    "@fastify/static": "^8",
    "@inquirer/prompts": "^8.5.2",
    "@modelcontextprotocol/sdk": "^1",
    "better-sqlite3": "^12",
    "chalk": "^5",
    "fastify": "^5",
    "smol-toml": "^1.7.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@ant-design/icons": "^6",
    "@dagrejs/dagre": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/better-sqlite3": "^7",
    "@types/node": "^22",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6",
    "@xyflow/react": "^12.11.2",
    "antd": "^6",
    "esbuild": "^0.28.1",
    "mermaid": "^11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10",
    "remark-gfm": "^4",
    "semantic-release": "^25.0.5",
    "tsx": "^4",
    "typescript": "^5.5.0",
    "vite": "^8"
  }
}
