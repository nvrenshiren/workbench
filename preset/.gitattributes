# Normalize all text files to LF on checkout & commit; auto-detect text vs binary.
* text=auto eol=lf

# Binary assets — never apply EOL conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.woff  binary
*.woff2 binary
